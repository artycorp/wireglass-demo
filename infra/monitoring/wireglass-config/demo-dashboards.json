{
  "version": 1,
  "schemas": [
    {
      "id": "demo-ping-response-valid",
      "name": "✅ Ping response (passes)",
      "pattern": "/api/fast/ping",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["id", "ts", "tier", "request_id"],
        "properties": {
          "id": { "type": "string", "minLength": 36, "maxLength": 36 },
          "ts": { "type": "integer", "minimum": 1000000000000 },
          "tier": { "type": "string", "enum": ["fast"] },
          "request_id": { "type": "string", "minLength": 36, "maxLength": 36 }
        }
      }
    },
    {
      "id": "demo-login-request-valid",
      "name": "✅ Login request body (passes)",
      "pattern": "/api/medium/login",
      "target": "request",
      "schema": {
        "type": "object",
        "required": ["username", "password"],
        "additionalProperties": false,
        "properties": {
          "username": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 6 }
        }
      }
    },
    {
      "id": "demo-orders-response-valid",
      "name": "✅ Orders response (passes)",
      "pattern": "/api/medium/orders/{id}",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["order_id", "user", "items", "total", "request_id"],
        "properties": {
          "order_id": { "type": "integer", "minimum": 1 },
          "user": { "type": "string", "minLength": 1 },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sku", "qty", "price"],
              "properties": {
                "sku": { "type": "string", "minLength": 3 },
                "qty": { "type": "integer", "minimum": 1 },
                "price": { "type": "number", "minimum": 0 }
              }
            }
          },
          "total": { "type": "number", "minimum": 0 },
          "tier": { "type": "string", "enum": ["medium"] }
        }
      }
    },
    {
      "id": "demo-report-response-valid",
      "name": "✅ Slow report response (passes)",
      "pattern": "/api/slow/report",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["count", "generated_ms", "rows", "request_id"],
        "properties": {
          "count": { "type": "integer", "minimum": 0 },
          "generated_ms": { "type": "integer", "minimum": 1000000000000 },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["idx", "value", "label"],
              "properties": {
                "idx": { "type": "integer", "minimum": 0 },
                "value": { "type": "number" },
                "label": { "type": "string", "minLength": 4 }
              }
            }
          },
          "tier": { "type": "string", "enum": ["slow"] }
        }
      }
    },
    {
      "id": "demo-ping-response-missing-field",
      "name": "❌ Ping response — required field missing",
      "pattern": "/api/fast/ping",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["id", "ts", "datacenter"],
        "properties": {
          "datacenter": { "type": "string" }
        }
      }
    },
    {
      "id": "demo-orders-response-wrong-type",
      "name": "❌ Orders response — wrong type on total",
      "pattern": "/api/medium/orders/{id}",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["order_id", "total"],
        "properties": {
          "order_id": { "type": "integer" },
          "total": { "type": "string" }
        }
      }
    },
    {
      "id": "demo-report-response-enum-mismatch",
      "name": "❌ Slow report — tier outside enum",
      "pattern": "/api/slow/report",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["tier", "count"],
        "properties": {
          "tier": { "type": "string", "enum": ["fast", "medium"] },
          "count": { "type": "integer", "maximum": 10 }
        }
      }
    },
    {
      "id": "demo-login-request-bounds",
      "name": "❌ Login request — bounds + missing field",
      "pattern": "/api/medium/login",
      "target": "request",
      "schema": {
        "type": "object",
        "required": ["username", "password", "mfa_code"],
        "properties": {
          "username": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 12 },
          "mfa_code": { "type": "string", "minLength": 6 }
        }
      }
    }
  ],
  "dashboards": [
    {
      "id": "demo-grafana-loadtest-dashboard",
      "name": "Grafana: loadtest dashboard",
      "system": "grafana",
      "scope": "global",
      "urlTemplate": "http://localhost:3000/d/wireglass-loadtest/wireglass-loadtest?orgId=1&from=now-1h&to=now"
    },
    {
      "id": "demo-grafana-loadtest-packet",
      "name": "Grafana: metrics around this request",
      "system": "grafana",
      "scope": "packet",
      "urlTemplate": "http://localhost:3000/d/wireglass-loadtest/wireglass-loadtest?orgId=1&from={fromMs}&to={toMs}",
      "match": ":8081"
    },
    {
      "id": "demo-jaeger-packet-search",
      "name": "Jaeger: search this request",
      "system": "custom",
      "scope": "packet",
      "urlTemplate": "http://localhost:16686/search?service=wireglass-loadtest-stand&lookback=custom&start={fromMs}000&end={toMs}000",
      "match": ":8081"
    },
    {
      "id": "demo-jaeger-all-traces",
      "name": "Jaeger: all traces",
      "system": "custom",
      "scope": "global",
      "urlTemplate": "http://localhost:16686/search?service=wireglass-loadtest-stand"
    },
    {
      "id": "demo-grafana-jaeger-explore",
      "name": "Grafana → Jaeger (Explore)",
      "system": "grafana",
      "scope": "global",
      "urlTemplate": "http://localhost:3000/explore?schemaVersion=1&panes=%7B%22trc%22%3A%7B%22datasource%22%3A%22jaeger%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22jaeger%22%2C%22uid%22%3A%22jaeger%22%7D%2C%22queryType%22%3A%22search%22%2C%22service%22%3A%22wireglass-loadtest-stand%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D%7D&orgId=1"
    },
    {
      "id": "demo-grafana-opensearch-explore",
      "name": "Grafana → OpenSearch Logs (Explore)",
      "system": "grafana",
      "scope": "global",
      "urlTemplate": "http://localhost:3000/explore?schemaVersion=1&panes=%7B%22logs%22%3A%7B%22datasource%22%3A%22opensearch%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22elasticsearch%22%2C%22uid%22%3A%22opensearch%22%7D%2C%22query%22%3A%22%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D%7D&orgId=1"
    }
  ]
}
