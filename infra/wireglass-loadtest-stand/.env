# Latency per tier in milliseconds (jitter applied as +/- JITTER_PCT)
FAST_MS=20
MED_MS=300
SLOW_MS=2000
JITTER_PCT=20

# Stateless HMAC token settings
TOKEN_SECRET=change-me-teststand-secret
TOKEN_TTL=3600

# Max rows the slow /report endpoint will generate
REPORT_MAX_ROWS=5000

# Jaeger OTLP/HTTP endpoint (via host.docker.internal, since the stand and infra/monitoring are
# separate compose projects) and the service name traces show up under in Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
OTEL_SERVICE_NAME=wireglass-loadtest-stand
